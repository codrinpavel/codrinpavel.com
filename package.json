{
  "type": "module",
  "name": "11ty-boilerplate",
  "version": "0.0.0",
  "private": true,
  "description": "11ty-based local development environment for static website projects",
  "license": "MIT",
  "author": "Codrin Pavel (https://codrin.eu/)",
  "contributors": [
    "Codrin Pavel <hello@codrin.eu>"
  ],
  "scripts": {
    "start:11ty": "eleventy --serve",
    "start:rollup": "rollup -c -w",
    "build:rollup": "rollup -c",
    "build:11ty": "npx @11ty/eleventy",
    "clean:dist": "rimraf dist",
    "clean:min": "rimraf dist/assets/min/",
    "start": "cross-env ELEVENTY_ENV=dev npm-run-all clean:dist -p start:*",
    "build": "cross-env ELEVENTY_ENV=production npm-run-all clean:dist build:* clean:min",
    "debug": "cross-env DEBUG=Eleventy:Benchmark* npm run start"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "autoprefixer": "^10.4.13",
    "cross-env": "^7.0.3",
    "eleventy-plugin-svg-contents": "^0.7.0",
    "html-minifier": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.21",
    "purgecss": "^8.0.0",
    "rimraf": "^4.1.2",
    "rollup": "^4.29.1",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.80.3"
  },
  "dependencies": {
    "lenis": "^1.3.23"
  }
}
