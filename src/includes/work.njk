{#
<section class="relative py-10xl" id="work" aria-labelledby="heading-work">
  <div class="wrapper">
    <h2 id="heading-work" class="sr-only">Work</h2>

    <div class="columns justify-between">
      <div class="md:columns-4 lg:columns-3">
        <nav class="work-filters" aria-label="Work filters">
          <ul class="mb-2xl">
            <li>
              <button type="button" class="type-large" aria-pressed="true" data-filter="all">collected works</button>
            </li>
            <li>
              <button type="button" class="type-large" aria-pressed="false" data-filter="award">awards + recognition</button>
            </li>
            <li>
              <button type="button" class="type-large" aria-pressed="false" data-filter="fortune">enterprise + fortune 500</button>
            </li>
          </ul>

          <hr/>

          <div class="stat" data-tags="all" hidden>
            <p class="text-sm">delivered</p>
            <span class="type-large mb-sm">80+ projects</span>
            <p class="font-light">across websites, platforms, reports, and interactive experiences for brands, agencies, and startups.</p>
          </div>

          <div class="stat--award" data-tags="award">
            <p class="text-sm">recipient of</p>
            <span class="type-large mb-sm">30+ Industry Awards</span>
            <p class="font-light">from GDUSA, WMA, LACP, ARC, and iNOVA for UI/UX and digital experiences.</p>
          </div>

          <div class="stat--fortune" data-tags="fortune" hidden>
            <p class="text-sm">supporting</p>
            <span class="type-large mb-sm">Fortune 500</span>
            <p class="font-light">organizations across energy, healthcare, aviation, pharmaceuticals, finance, education, and government.</p>
          </div>
        </nav>
      </div>

      <div class="md:columns-12 mt-10xl">
        <table class="work-table" data-filter="all">
          <caption class="sr-only">Client work by project and year</caption>

          <thead class="sr-only">
            <tr>
              <th scope="col">Client</th>
              <th scope="col">Project</th>
              <th scope="col">Year</th>
            </tr>
          </thead>

          <tbody>
            {%- for item in work | sortByYear -%}
              {% set url = item.wayback and ("https://web.archive.org/web/" ~ item.wayback ~ "if_/" ~ item.url) or item.url %}

              <tr data-client="{{ item.client }}" data-tags="all, {{ item.tags | join(', ') if item.tags }}">
                <td>{{- item.client -}}</td>

                <td>
                  {%- if item.inactive -%}
                    {{- item.project  | safe -}}
                  {%- else -%}
                    <a class="link" href="{{ url }}" class="link" target="_blank" rel="noopener noreferrer">{{- item.project | safe -}}</a>
                  {%- endif -%}

                  {%- if item.awards -%}
                    <ol class="work-table__awards flex flex-col row-gap-md">
                      {%- for award in item.awards -%}
                        <li>
                          <a class="link" href="{{ award.url }}" target="_blank" rel="noopener noreferrer">{{ award.organization }}&mdash;{{ award.title }}</a>
                        </li>
                      {%- endfor -%}
                    </ol>
                  {%- endif -%}
                </td>

                <td>{{ item.year }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
#}

<section class="pb-5xl" id="work" aria-labelledby="heading-work">
  <div class="wrapper">
    <h2 id="heading-work">Complete Works<sup>{{work.length}}</sup></h2>

    <ul class="work type-eyebrow">
      {%- for item in work | sortByYear -%}
        {% set url = item.wayback and ("https://web.archive.org/web/" ~ item.wayback ~ "if_/" ~ item.url) or item.url %}

        <li {% if item.inactive %}class="is-disabled"{% endif %}>
          {%- if not item.inactive -%}
          <a href="{{ url }}" target="_blank" rel="noopener noreferrer">
          {%- endif -%}
            <p>{{- item.client -}}</p>
            <p>{{- item.project  | safe -}}</p>
            <p>
              <span>{{- item.year -}}</span>
              {%- if not item.inactive -%}<span class="hidden">View</span>{%- endif -%}
            </p>
          {%- if not item.inactive -%}
          </a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>