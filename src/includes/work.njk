{% set sortedWork = work | sortByYear %}

<section class="work" id="work">
  <div class="wrapper flex column-gap-2xl">
    <ul class="flex flex-col">
      {% for item in sortedWork %}
        {% if item.tags and "featured" in item.tags %}
          {% set clientSlug = item.client | lower | replace(' ', '-') | replace('|', '') %}
          <li>
            <a class="js-project" href="#{{clientSlug}}-{{item.year}}">{{ item.client }} &mdash; {{ item.project }}</a>
          </li>
        {% endif %}
      {% endfor %}
    </ul>

    {%- for category in projects -%}
    <div>
      <h2>{{category.title}} ({{category.count}})</h2>
      <ul>
        {%- for client in category.clients -%}
          {% set project_count = (client.projects.length > 1) and ("×" ~ client.projects.length)or '' %}

          <li>
            {{client.name}}
            {{project_count | safe}}
          </li>
        {%- endfor -%}
      </ul>
    </div>
    {%- endfor -%}
  </div>
</section>