{% set sortedWork = work | sortByYear %}

<section class="work" id="work">
  <div class="wrapper">
    {#}
    <div class="flex">
      {% svg "company/paper.svg" %}
      {% svg "company/axios.svg" %}
      {% svg "company/nyu.svg" %}
      {% svg "company/gsk.svg" %}
      {% svg "company/nrmp.svg" %}
      {% svg "company/rtx.svg" %}
      {% svg "company/dominion-energy.svg" %}
      {% svg "company/united.svg" %}
      {% svg "company/fnih.svg" %}
      {% svg "company/agco.svg" %}
    </div>
    {##}
    <div class="columns">
      <div class="lg:columns-5 lg:ml-2 work__selected">
        <h2>Featured Work</h2>
        <ul>
          {% for item in sortedWork %}
            {% if item.tags and "featured" in item.tags %}
              {% set clientSlug = item.client | lower | replace(' ', '-') | replace('|', '') %}
              <li>
                <a class="js-project link" href="#{{clientSlug}}-{{item.year}}">
                  {{ item.client }}, {{ item.year }}
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <div class="lg:columns-4">
        <h2>Spotlight on: FNIH 2018&mdash;2022</h2>

        <figure class="spotlight">
          <video id="spotlight-video" width="1440" height="900" src="{{ '/assets/video/fnih.mp4' | url }}" muted playsinline loop></video>
          <button type="button" class="video-btn" aria-label="Play video" aria-controls="spotlight-video" id="spotlight-video-toggle">
            {% svg "play-button.svg" %}
          </button>
          <figcaption class="sr-only">Animated homepage designs from the Foundation for the National Institutes of Health (FNIH) annual reports, featuring the 2018, 2019, and 2020 editions.</figcaption>
        </figure>

        <div class="columns columns-6">
          <div class="work__list">
            <h2>Capabilities</h2>
            <ul>
              <li>Sustainability Reports</li>
              <li>Corporate Communications</li>
              <li>Annual Reports</li>
              <li>Investor Relations Websites</li>
              <li>Microsites & Campaign Sites</li>

              <li>Static Site Architecture</li>
              <li>Data Visualization</li>
              <li>Interactive Charts & Tables</li>
              <li>Accessibility (WCAG)</li>
              <li>Performance Optimization</li>
              <li>Analytics & Measurement</li>
              <li>Technical Consulting</li>
            </ul>

            <h2 class="mt-6xl">Technology</h2>
            <ul>
              <li>11ty</li>
              <li>Jekyll</li>

              <li>HTML</li>
              <li>CSS / SCSS</li>
              <li>JavaScript</li>
              <li>Node.js</li>

              <li>Nunjucks</li>
              <li>Liquid</li>
              <li>Jinja2</li>
            </ul>
          </div>

          <div class="work__list">
            <h2>Client Index</h2>
            {%- for project in projects -%}
              <ul>
                <li {% if project.count > 1 %}data-count="{{project.count}}"{%endif%}>
                  {{project.name}}
                </li>
              </ul>
            {%- endfor -%}

          </div>
        </div>
      </div>
    </div>

  </div>
</section>