{% set sortedWork = work | sortByYear %}

<section class="work" id="work" aria-labelledby="heading-work">
  <div class="wrapper">
    <div class="columns">
      <div class="columns-11 md:ml-1 flex column-gap-2xl">

        {%- for cat in projects -%}
          <ul class="flex flex-col">
            <li>
              <h2>{{cat.title}}</h2>
            </li>

            {%- for client in cat.clients -%}
              <li>
                {{client.name}}
                {% if client.projects.length > 1 %} ({{client.projects.length}}) {% endif %}
              </li>
            {%- endfor -%}
          </ul>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>