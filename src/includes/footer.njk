<footer class="site-footer">
  <div class="wrapper">
    <div class="columns items-end">
      <div class="md:columns-5 md:ml-auto">
        {% set text = "Inquiries:" %}

        <p class="type-xlarge color-faint flex flex-wrap" data-reveal-batch>
          {%- for char in text.split(' ') -%}
            <span class="overflow-hidden flex">
              <i data-reveal data-stagger="150">{{ char }}</i>&nbsp;
            </span>
          {%- endfor -%}
        </p>

        <ul class="mt-10xl">
          <li data-reveal>
            <a href="mailto:hello@codrin.eu" target="_blank" rel="noopener noreferrer">
              <span>Email</span>
              <span>hello@codrin.eu</span>
            </a>
          </li>
          <li data-reveal>
            <a href="https://www.linkedin.com/in/codrin-pavel/" target="_blank" rel="noopener noreferrer">
              <span>LinkedIn</span>
              <span>Codrin Pavel</span>
            </a>
          </li>
          <li data-reveal>
            <a href="https://github.com/ZeroSpree" target="_blank" rel="noopener noreferrer">
              <span>GitHub</span>
              <span>@zerospree</span>
            </a>
          </li>
        </ul>
      </div>
      <div class="type-huge mt-10xl">
        codrin/pavel
      </div>
    </div>
  </div>
</footer>

