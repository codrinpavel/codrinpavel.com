<footer class="site-footer">
  <div class="wrapper">
    <div>
      <p class="type-xlarge color-faint-balance">Available for interface implementation & consulting.</p>
      <p class="type-xlarge m-zero">
        <a class="link" href="mailto:hello@codrin.eu">hello@codrin.eu</a>
      </p>
    </div>

    <div class="columns items-end type-eyebrow">
      <div class="columns-6 md:columns-7 md:order-first">
        <span class="type-huge font-black color-faint-balance">C/P</span>
      </div>

