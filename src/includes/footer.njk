        <h2 class="color-faint">Selected Work</h2>

        <ul class="columns columns-6">
          {% for item in collections.work | order %}
            <li>
              <a class="link" href="{{item.url | url}}" {% if page.url == item.url %}aria-current="page"{% endif %}>{{item.data.client}}</a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="columns-1 ml-auto">
        <ul class="flex flex-col items-end">
          <li>
            <a class="link" href="https://www.linkedin.com/in/codrin-pavel/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </li>
          <li>
            <a class="link" href="https://github.com/ZeroSpree" target="_blank" rel="noopener noreferrer">GitHub</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>