<section class="w pt-header-offset-xs" id="work" aria-labelledby="heading-work">
  <div class="wrapper">
    <div class="columns">
      <div class="md:columns-4 lg:columns-3 w__header">
        <div class="sticky top-header-offset-xs">
          <h2 id="heading-work">Work<sup>{{work.length}}</sup></h2>
        </div>
        <div class="w__meta">
          {%- for item in work | sortByYear -%}
            <div data-id="work-{{loop.index}}">
              <h3 class="mb-zero">{{ item.long or item.client | safe }} &mdash; {{ item.project | safe }}</h3>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <div class="md:columns-4 lg:columns-3">
        <ul>
          {%- for item in work | sortByYear -%}
            <li data-id="work-{{loop.index}}" {% if item.inactive %}class="is-disabled"{% endif %}>{{- item.client -}}</li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="md:columns-4 lg:columns-6">
        <div class="w__image">
        {%- for item in work | sortByYear -%}
          {% if not item.nothumb %}
            {% set url = 'work/' ~ item.client | lower | replace(' ', '-') | replace('|', '') ~ '-' ~ item.project | lower | replace(' ', '-') ~ '-' ~ item.year ~ '.png' %}
            <figure data-id="work-{{loop.index}}">
                {% img url %}
            </figure>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>