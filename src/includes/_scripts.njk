<script>
window.PAGE_ORDER = {
  "/": -1,
  {%- for page in collections.pages | order -%}
    "{{page.url}}": {{loop.index*100}},
  {%- endfor -%}
  {%- for page in featured -%}
    "/{{ page.client | slugify }}-{{page.year}}/": {{loop.index+10}}
    {%- if not loop.last -%},{%- endif -%}
  {% endfor %}
};
</script>


{%- if global.environment == "production" -%}
  --INLINE JS--
{%- else -%}
  <script src="/assets/min/main.min.js"></script>
{%- endif -%}
