<section class="hero" id="top" aria-labelledby="heading-hero">
  <div class="wrapper">
    <h1 id="heading-hero" class="sr-only">About me</h1>

    <div class="overflow-hidden">
      <div class="hero__track">
        <div class="hero__track--intro hero__track--item heading">
          <p class="animate-wave" data-delay="2800">Design-driven frontend developer focused on accessibility and optimization, creating award-winning experiences that are beautifully performant.</p>
        </div>

        {% for item in quotes %}
          <figure class="quote hero__track--item">
            <span class="type-eyebrow quote__page">
              {{ loop.index < 10 and '0' ~ loop.index or loop.index }}
              &mdash;
              {{ loop.length < 10 and '0' ~ loop.length or loop.length }}
            </span>

            <blockquote>
              <p>{{ item.content | safe }}</p>
            </blockquote>

            <figcaption>
              <cite>{{ item.name }}</cite>
              <span>{{ item.title }} at {{ item.company }}</span>
            </figcaption>
          </figure>
        {% endfor %}
      </div>
    </div>
  </div>
</section>