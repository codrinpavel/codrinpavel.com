{% set nav = ["About", "Stats", "Words", "Awards", "Lab"] %}

{% set logo %}
<a href="/" class="site-logo" data-inview>
  <div class="flex overflow-hidden">
    <span data-rickroll="Codrin"><b>Codrin</b></span>
    <span>/</span>
    <span data-rickroll="Pavel"><b>Pavel</b></span>
  </div>
</a>
{% endset %}

<header class="header">
  <nav class="wrapper header__nav">
    <ul class="columns md:hidden">
      <li class="columns-6">{{logo|safe}}</li>
      <li class="columns-6 flex items-center justify-between">
        <span class="color-faint">{{title or client}}</span>

        <button class="menu-button type-regular" aria-controls="menu" aria-expanded="false">
          <span><b>Menu</b><b>Close</b></span>
        </button>
      </li>
    </ul>

    <ul class="columns md:columns-1 items-center hidden md:flex">
      <li class="mr-auto">{{logo|safe}}</li>

      {% for item in collections.nav | order %}
        <li {% if loop.first %}class="md:columns-1"{%endif%}>
          <a class="link {% if page.url.indexOf(item.url) == 0 %}color-faint{% endif %}" {% if page.url == item.url %} aria-current="page"{% endif %} href="{{item.url | url}}">{{item.data.title}}</a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  <nav class="menu">
    <ul>
    {% for item in collections.nav | order %}
      <li style="--index:{{loop.index}}">
        <a {% if page.url.indexOf(item.url) == 0 %}class="color-faint"{% endif %} {% if page.url == item.url %} aria-current="page"{% endif %} href="{{item.url | url}}">{{item.data.title}}</a>
      </li>
    {% endfor %}
    </ul>
  </nav>
</header>