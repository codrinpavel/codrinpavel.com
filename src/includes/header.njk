{% set nav = ["About", "Stats", "Words", "Awards", "Lab"] %}

{% set logo %}
<a href="/" class="site-logo">
  <span class="vt-logo-1">Codrin</span>
  <span>/</span>
  <span class="vt-logo-2">Pavel</span>
</a>
{% endset %}

<header class="header">
  <nav class="wrapper">

    <ul class="header__mobile columns columns-4">
      <li>{{logo|safe}}</li>
      <li class="text-center">Menu</li>
      <li>0{{order + 1}}&mdash;{{title}}</li>
    </ul>

    <ul class="header__desktop columns columns-3 md:columns-1">
      <li>{{logo|safe}}</li>

      <li class="md:columns-6">
        <a class="link type-headline js-project" href="{{"/gallery/stanley-black-and-decker-2021/" | url}}">Gallery</a>
      </li>

      {% for item in collections.pages | order %}
        <li>
          <a class="link type-headline" {% if page.url == item.url %} aria-current="page"{% endif %} href="{{item.url | url}}">{{item.data.title}}</a>
        </li>
      {% endfor %}
    </ul>
  </nav>
</header>