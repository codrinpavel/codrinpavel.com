        <a href="#home" class="site-logo">
          {% svg "logo.svg" %}
          <span class="sr-only">Codrin Pavel</span>
        </a>
      </li>

      <li class="site-header__item lg:columns-6">
        <a class="link type-headline js-project" href="#stanley-black-and-decker-2021">Gallery</a>
