{% set nav = ["About", "Motion", "Work", "Awards", "Out of Scope"] %}

{% set awardCount = 0 %}

{% for group in awards %}
  {% set awardCount = awardCount + group.awards.length %}
{% endfor %}

<header class="site-header">
  <nav class="wrapper">
    <ul class="columns md:columns-2 lg:columns-1 items-end">
      <li class="site-header__item lg:columns-6">
        <a href="#home" class="site-logo">{% svg "logo.svg" %} <span class="sr-only">Codrin Pavel</span></a>
      </li>
      {% for item in nav %}
      <li class="site-header__item" style="--index: {{loop.index}}">
        <a class="link" style="--delay: 2400ms;" href="#{{item | lower | replace(' ', '-')}}">
          {{item}}
          {% if item == "Work" %}
          ({{work.length}})
          {% elif item == "Awards" %}
          ({{awardCount}})
          {% endif %}
        </a>
      </li>
      {% endfor %}
    </ul>
  </nav>
</header>