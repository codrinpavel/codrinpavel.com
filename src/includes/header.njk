{% set nav = ["About", "Stats", "Words", "Awards", "Lab"] %}

{% set logo %}
<a href="/" class="site-logo">
  <span class="vt-logo-1">Codrin</span>
  <span>/</span>
  <span class="vt-logo-2">Pavel</span>
</a>
{% endset %}

<header class="header">
  <nav class="wrapper header__nav">
    <ul class="header__mobile columns columns-4">
      <li>{{logo|safe}}</li>
      <li class="text-center">0{{order}}&mdash;{{title}}</li>
      <li>
        <button class="menu-button type-regular" aria-controls="menu" aria-expanded="false">
          <span><b>Menu</b><b>Close</b></span>
        </button>
      </li>
    </ul>

    <ul class="header__desktop columns columns-3 lg:columns-1">
      <li>{{logo|safe}}</li>

      {% for item in collections.nav | order %}
        <li {% if loop.first %}class="mr-auto"{% endif %}>
          <a class="link type-headline" {% if page.url == item.url %} aria-current="page"{% endif %} href="{{item.url | url}}">{{item.data.title}}</a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  <nav class="menu" >
    <ul class="wrapper">
    {% for item in collections.nav | order %}
      <li style="--index:{{loop.index}}">
        <a {% if page.url == item.url %} aria-current="page"{% endif %} href="{{item.url | url}}">{{item.data.title}}</a>
      </li>
    {% endfor %}
    </ul>
  </nav>
</header>