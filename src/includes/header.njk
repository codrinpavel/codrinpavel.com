{% set nav = ["About", "Stats", "Words", "Awards", "Lab"] %}

{% set logo %}
<a href="/" class="site-logo">
  <span class="vt-logo-1">Codrin</span>
  <span>/</span>
  <span class="vt-logo-2">Pavel</span>
</a>
{% endset %}

<header class="header">
  <nav class="wrapper header__nav">
    <ul class="header__mobile columns columns-4">
      <li>{{logo|safe}}</li>
      <li class="text-center">{{title}}</li>
      <li>
        <button class="menu-button type-regular" aria-controls="menu" aria-expanded="false">
          <span><b>Menu</b><b>Close</b></span>
        </button>
      </li>
    </ul>

    <ul class="header__desktop columns md:columns-1">
      <li class="mr-auto">{{logo|safe}}</li>

      {% for item in collections.nav | order %}
        <li {% if loop.first %}class="md:columns-2"{%endif%}>
          <a class="link" {% if page.url == item.url %} aria-current="page"{% endif %} href="{{item.url | url}}">{{item.data.title}}</a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  <nav class="menu">
    <ul>
    {% for item in collections.nav | order %}
      <li style="--index:{{loop.index}}">
        <a {% if page.url == item.url %} aria-current="page"{% endif %} href="{{item.url | url}}">{{item.data.title}}</a>
      </li>
    {% endfor %}
    </ul>

    <div class="menu__contact">
      <ul class="flex color-black-text gap-2xl type-headline upperacase font-bold">
        <li><a href="https://www.linkedin.com/in/codrin-pavel/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
        <li><a href="https://github.com/ZeroSpree" target="_blank" rel="noopener noreferrer">GitHub</a></li>
        <li><a href="mailto:hello@codrin.eu" target="_blank" rel="noopener noreferrer">hello@codrin.eu</a></li>
      </ul>
    </div>
  </nav>
</header>