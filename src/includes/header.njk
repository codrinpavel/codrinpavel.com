{% set nav = ["About", "Work", "Words", "Awards", "Lab"] %}
{% set awardCount = 0 %}

{% for group in awards %}
  {% set awardCount = awardCount + group.awards.length %}
{% endfor %}

<header class="site-header">
  <nav class="wrapper">
    <ul class="columns md:columns-2 lg:columns-1 items-start">
      <li class="site-header__item lg:columns-7">
        <a href="#home" class="site-logo">
          {% svg "logo.svg" %}
          <span class="sr-only">Codrin Pavel</span>
        </a>
      </li>

      {% for item in nav %}
        <li class="site-header__item">
          <a class="link type-headline" href="#{{item | lower | replace(' ', '-')}}">
            {% if item == "Work" %}
              {{work.length}}&times;
            {% elif item == "Awards" %}
              {{awardCount}}&times;
            {% endif %}
              {{item}}
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>
</header>