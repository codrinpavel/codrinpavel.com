---
layout: base.njk
preload: "portrait-tall-optimized.jpg"
title: "Home"
meta_title: "Codrin Pavel / Independent Frontend Developer & Consultant"
order: 0
---

{% set sortedWork = work | sortByYear %}

<section class="home">
  <div class="wrapper">
    <div class="screen screen--reveal">
      <div class="columns --row-gap-4xl">
        <div class="columns-12 md:columns-7">
          {% set intro = "For more than 15 years, I've partnered with agencies, publishers, and organizations to build accessible, high-performance websites, reports, and media platforms. Based in the Canary Islands of Spain, I work remotely with clients across the United States and Europe." %}

          <h1 class="flex flex-wrap text-4xl" data-reveal-batch>
            {%- for char in intro.split(' ') -%}
              <span class="overflow-hidden flex">
                <i data-reveal data-stagger="15">{{ char }}</i>&nbsp;
              </span>
            {%- endfor -%}
          </h1>
        </div>

        <div class="columns-6 md:columns-3 lg:columns-2" data-reveal="clipy">
          {% img "portrait-tall-optimized.jpg", "", "", "eager" %}
        </div>
      </div>
    </div>

    <div class="columns md:columns-5 justify-end mt-10xl">
      {% set i = 0 %}

      {% for page in collections.work %}
        {% if page.data.title in["United Airlines","NRMP","FNIH","AXIOS Media","NYU","Dominion Energy"] %}
          {% set i = i + 1 %}
          <a class="card card--logo" href="{{ page.url | url }}">
            {%- set svg_url = 'company/' ~ page.data.title | slugify ~ '.svg' -%}
            <div class="card__index">{{ i < 10 and '0' + i or i }}.</div>
            <h2>{{page.data.type}}</h2>

            <figure data-reveal data-stagger="250">
              {% svg svg_url, "" %}
            </figure>
          </a>
        {% endif %}
      {% endfor %}
    </div>

    <div class="columns --row-gap-8xl mt-10xl pt-10xl">
      <div class="md:columns-5 text-md" data-reveal-batch>
        <h2 class="color-faint" data-reveal data-delay="400">About</h2>
        {% set desc1 = "I enjoy working closely with strategists and designers, and pride myself on the quality of my work." %}

        {% set desc2 = "The best projects I’ve been part of include reporting programs for Dominion Energy, FNIH, Brilliant Earth, AGCO, Tradeweb, and Stanley Black & Decker; enterprise platforms for NRMP, United and MyGov.us; publishing systems for Axios, The Dodo, PAPER, Discovery, and many others." %}

        {% set desc3 = "I started my career building government software, so attention to detail, accessibility, and performance have shaped the way I approach every project ever since. Development is where I spend most of my time, but not all of it. I've worked closely with clients, collaborated with designers to improve workflows, onboarded teammates, and made sure everyone understood what we were building, in plain English." %}

        <p class="flex flex-wrap type-medium mb-2xl">
        {%- for char in desc1.split(' ') -%}
          <span class="overflow-hidden flex"><i data-reveal data-stagger="5">{{ char }}</i>&nbsp;</span>
        {%- endfor -%}
        </p>

        <p class="flex flex-wrap mb-2xl">
        {%- for char in desc2.split(' ') -%}
          <span class="overflow-hidden flex"><i data-reveal data-stagger="5">{{ char }}</i>&nbsp;</span>
        {%- endfor -%}
        </p>

        <p class="flex flex-wrap">
        {%- for char in desc3.split(' ') -%}
          <span class="overflow-hidden flex"><i data-reveal data-stagger="5">{{ char }}</i>&nbsp;</span>
        {%- endfor -%}
        </p>
      </div>

      <div class="columns-6 md:columns-3 md:ml-2" data-reveal-batch>
        <h2 class="color-faint" data-reveal>Services</h2>
        <ul>
          <li data-reveal>Annual & Sustainability Reports</li>
          <li data-reveal>Corporate Communications</li>
          <li data-reveal>Investor Relations Websites</li>
          <li data-reveal>Reporting & Data Visualization</li>
          <li data-reveal>Accessibility Audits & WCAG Compliance</li>
          <li data-reveal>Performance Optimization</li>
          <li data-reveal>Microsites & Campaign Sites</li>
          <li data-reveal>Bespoke Animations</li>
          <li data-reveal>Static Site Architecture</li>
          <li data-reveal>Technical Consulting</li>
        </ul>
      </div>

      <div class="columns-6 md:columns-2" data-reveal-batch>
        <h2 class="color-faint" data-reveal>Expertise</h2>
        <ul>
          <li data-reveal>Frontend Architecture</li>
          <li data-reveal>ARIA & Assistive Technology</li>
          <li data-reveal>Interactive Storytelling</li>
          <li data-reveal>Performance Engineering</li>
          <li data-reveal>User Experience (UX)</li>
          <li data-reveal>Design Systems</li>
          <li data-reveal>Data Visualization</li>
          <li data-reveal>Enterprise Systems</li>
          <li data-reveal>Eleventy & Static Architecture</li>
          <li data-reveal>SEO & Structured Data</li>
        </ul>
      </div>
    </div>

    <div class="columns columns-6 --row-gap-8xl mt-10xl pt-10xl">
      <div class="md:columns-5 ml-auto text-md" data-reveal-batch>
        {% set archivetext = "Below is a complete archive of 87 commercial projects spanning 17 years—from corporate communications and interactive experiences to high-traffic media publishing and enterprise platforms." %}

        <p class="flex flex-wrap color-faint">
        {%- for char in archivetext.split(' ') -%}
          <span class="overflow-hidden flex"><i data-reveal data-stagger="5">{{ char }}</i>&nbsp;</span>
        {%- endfor -%}
        </p>
      </div>
    </div>

    <div class="archive">
      <ul aria-label="Work Archive">
        <li data-reveal class="columns">
          <span class="columns-6 md:columns-7 border-b-1">Projects</span>
          <span class="columns-6 md:columns-4 lg:columns-3 border-b-1">Client</span>
          <span class="md:columns-1 lg:columns-2 border-b-1">Years</span>
        </li>

        {%- for item in work -%}
          {% set isCaseStudy = collections.work | hasCaseStudy(item.client) %}
          <li data-reveal data-stagger="25" {% if not isCaseStudy %}class="columns"{% endif %} style="--i: {{ loop.index }}">
            {%- if isCaseStudy -%}
              <a href="/work/{{item.client | slugify}}/" class="columns">
                <span class="columns-6 md:columns-7 flex gap-sm">{{item.project}}</span>
                <span class="columns-6 md:columns-4 lg:columns-3" data-client="{{item.long or item.client}}">{{item.client}}</span>
                <span class="md:columns-1 lg:columns-2">{{item.year}}</span>
              </a>
            {% else %}
              <span class="columns-6 md:columns-7">{{item.project}}</span>
              <span class="columns-6 md:columns-4 lg:columns-3" data-client="{{item.long or item.client}}">{{item.client}}</span>
              <span class="md:columns-1 lg:columns-2">{{item.year}}</span>
            {% endif %}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</section>