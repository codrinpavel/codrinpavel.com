---
layout: base.njk
htmlClass: "home"
preload: "portrait-tall.jpg"
title: "Home"
order: 0
---

{% set sortedWork = work | sortByYear %}

<section class="home" id="home">
  <div class="wrapper">
    <div class="columns mb-10xl">
      <div class="columns-12 md:columns-7">
        {% set intro = "For more than 15 years, I’ve been an independent frontend partner to agencies, publishers, nonprofits, and enterprise teams, turning creative concepts and complex content into accessible, high-performance websites, reports, and media platforms." %}

        <h1 class="type-xlarge flex flex-wrap" data-reveal-batch>
          {%- for char in intro.split(' ') -%}
            <span class="overflow-hidden flex"><i data-reveal data-stagger="15">{{ char }}</i>&nbsp;</span>
          {%- endfor -%}
        </h1>
      </div>

      <div class="columns-6 md:columns-5 lg:columns-2" data-reveal="clipy">
        {% img "portrait-tall.jpg", "", "", "eager" %}
      </div>
    </div>

    <div class="columns my-10xl --row-gap-5xl">
      <div class="columns-10 md:columns-5 text-md">
        <h2 data-reveal data-delay="300">Experience</h2>
        {% set desc1 = "I love staying close to the process and take great pride in the quality of my work." %}

        {% set desc2 = "The best projects I’ve been part of had teams that truly care: reporting programs for Dominion Energy, FNIH, Brilliant Earth, AGCO, Tradeweb, and Stanley Black & Decker; enterprise platforms for NRMP and United; publishing systems for Axios, The Dodo, PAPER, Discovery, SI and so many others." %}

        {% set desc3 = "Across all these projects, I’ve contributed more than code: interpreting client feedback, explaining technical decisions in plain english, reviewing code, onboarding developers, and enabling creatives and teammates do their best work." %}

        <p class="flex flex-wrap text-lg">
        {%- for char in desc1.split(' ') -%}
          <span class="overflow-hidden flex"><i data-reveal data-stagger="5">{{ char }}</i>&nbsp;</span>
        {%- endfor -%}
        </p>

        <p class="flex flex-wrap">
        {%- for char in desc2.split(' ') -%}
          <span class="overflow-hidden flex"><i data-reveal data-stagger="5">{{ char }}</i>&nbsp;</span>
        {%- endfor -%}
        </p>

        <p class="flex flex-wrap">
        {%- for char in desc3.split(' ') -%}
          <span class="overflow-hidden flex"><i data-reveal data-stagger="5">{{ char }}</i>&nbsp;</span>
        {%- endfor -%}
        </p>
      </div>

      <div class="columns-6 md:columns-3 md:ml-2">
        <h2 data-reveal data-delay="200">Services</h2>
        <ul>
          <li data-reveal>Annual & Sustainability Reports</li>
          <li data-reveal>Corporate Communications</li>
          <li data-reveal>Investor Relations Websites</li>
          <li data-reveal>Microsites & Campaign Sites</li>
          <li data-reveal>Data Visualization</li>
          <li data-reveal>Bespoke Animations</li>
          <li data-reveal>Accessibility (WCAG)</li>
          <li data-reveal>Performance Optimization</li>
          <li data-reveal>Static Site Architecture</li>
          <li data-reveal>Technical Consulting</li>
        </ul>
      </div>

      <div class="columns-4 md:columns-2 ml-1 md:ml-zero">
        <h2 data-reveal data-delay="200">Expertise</h2>
        <ul>
          <li data-reveal>Frontend Architecture</li>
          <li data-reveal>Accessibility / WCAG Compliance</li>
          <li data-reveal>Interactive Storytelling</li>
          <li data-reveal>Performance Engineering</li>
          <li data-reveal>User Experience</li>
          <li data-reveal>Design Systems</li>
          <li data-reveal>Data Visualization</li>
          <li data-reveal>Enterprise Systems</li>
          <li data-reveal>11ty & Static Architecture</li>
          <li data-reveal>SEO & Structured Data</li>
        </ul>
      </div>
    </div>

    <div class="columns md:columns-6 lg:columns-4 justify-center my-10xl">
      {% set i = 0 %}

      {% for page in collections.work %}
        {% if page.data.client in["United Airlines","NRMP","FNIH","AXIOS Media","NYU","Dominion Energy"] %}
          {% set i = i + 1 %}
          <div data-reveal data-stagger="250" class="card card--logo">
            {%- set svg_url = 'company/' ~ page.data.client | slugify ~ '.svg' -%}
            <div class="card__index">{{ i < 10 and '0' + i or i }}.</div>

            <a href="{{ page.url | url }}">
              <h2>{{page.data.type}}</h2>
              {% svg svg_url, "" %}
            </a>
          </div>
        {% endif %}
      {% endfor %}
      <div>
        <a class="button" href="{{ "/work/" | url }}">See More Case Studies {% svg "arrow.svg" %}</a>
      </div>
    </div>

    <ul class="home__work my-10xl" role="table" aria-label="Work">
      <li data-reveal class="columns font-black color-black-text" role="row">
        <span role="columnheader" class="columns-6 md:columns-6 lg:columns-7 border-b-1">Client</span>
        <span role="columnheader" class="columns-6 md:columns-5 lg:columns-3 border-b-1">Website</span>
        <span role="columnheader" class="md:columns-1 lg:columns-2 border-b-1">Year</span>
      </li>

      {%- for item in work -%}
        {% set isCaseStudy = collections.work | hasCaseStudy(item.client) %}
        <li data-reveal data-stagger="15" {% if not isCaseStudy %}class="columns"{% endif %} role="row">
          {%- if isCaseStudy -%}
            <a href="/work/{{item.client | slugify}}/" class="columns">
          {% endif %}
            <span role="rowheader" class="columns-6 md:columns-6 lg:columns-7">{{item.client}}</span>
            <span role="cell" class="columns-6 md:columns-5 lg:columns-3">{{item.project}}</span>
            <span role="cell" class="md:columns-1 lg:columns-2">{{item.year}}</span>
          {%- if isCaseStudy -%}
            </a>
          {% endif %}
        </li>
      {%- endfor -%}
    </ul>

    <video width="1440" height="900" data-src="{{ '/assets/video/fnih.mp4' | url }}" aria-label="Animated showreel, showcasing motion and designs from various projects over the years." muted playsinline loop></video>
  </div>
</section>