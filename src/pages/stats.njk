---
layout: base.njk
htmlClass: "stats has-scroller"
title: "Stats"
order: 5
---

<section class="stats fullscreen" id="stats">
  <div class="wrapper scroller" style="--count: {{stats.length + 1}}">
    <div class="scroller__track">

      {% for stat in stats %}
        <div class="scroller__item">
          <div class="stat">
            <span class="figure type-huge">
              {%- for char in stat.figure.split('') -%}
                <i data-reveal data-stagger="100">{{- char -}}</i>
              {%- endfor -%}
            </span>

            <span data-reveal class="type-medium">{{ stat.title }}</span>

            <ul class="mt-auto">
              {%- for bullet in stat.bullets -%}
                <li data-reveal><span>{{- bullet -}}</span></li>
              {%- endfor -%}
            </ul>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>