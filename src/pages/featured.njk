---
layout: base.njk
htmlClass: "featured"
title: "Featured"
order: 2
---

<section class="featured" id="featured">
  <div class="wrapper">
    <div class="columns md:columns-6 lg:columns-5 justify-between --row-gap-8xl --column-gap-8xl">
      {% for item in featured %}
        {%- set image_url = 'work/' ~ item.client | slugify ~ '-' ~ item.project | slugify ~ '-' ~ item.year ~ '.png' -%}
        {%- set permalink = "/featured/" ~ item.client | slugify ~ "-" ~ item.year ~ "/" -%}

        <figure class="select">
          <a href="{{ permalink | url }}"></a>

          <div class="select__img">
            {% img image_url,
            "" %}
            {% img image_url,
            "" %}
          </div>

          <figcaption class="type-headline">
            <div>
              <span>Client</span>
              <span class="color-black-text">{{item.client}}</span>
            </div>
            <div>
              <span>Project</span>
              <span class="color-black-text">{{item.project}}</span>
            </div>
          </figcaption>
        </figure>

      {% endfor %}
    </div>
  </div>
</section>