---
layout: base.njk
htmlClass: "selected"
title: "Selected"
order: 1
override:tags: ["nav"]
---


<section class="selected" id="selected">
  <div class="wrapper">
    <div class="columns">
      <div class="lg:columns-7">
        <div class="columns md:columns-6 lg:columns-2 --row-gap-8xl --column-gap-8xl">
        {% for item in featured %}
          {%- set image_url = 'work/' ~ item.client | slugify ~ '-' ~ item.project | slugify ~ '-' ~ item.year ~ '.png' -%}
          {%- set permalink = "/selected/" ~ item.client | slugify ~ "-" ~ item.year ~ "/" -%}

          <figure class="select lg:mr-1">
            <a href="{{ permalink | url }}"></a>

            <div class="select__img">
              {% img image_url, "" %}
              {% img image_url, "" %}
            </div>

            <figcaption class="type-headline">
              <div>
                <span>Client</span>
                <span class="color-black-text">{{item.client}}</span>
              </div>
              <div>
                <span>Project</span>
                <span class="color-black-text">{{item.project}}</span>
              </div>
            </figcaption>
          </figure>

        {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>