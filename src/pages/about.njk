---
layout: base.njk
htmlClass: "about"
title: "About"
order: 2
---

{% set sortedWork = work | sortByYear %}

<section class="about" id="about">
  <div class="wrapper">
    <div class="columns mb-8xl lg:mb-10xl row-gap-8xl">
      <div class="columns-12 lg:columns-6">
        <p class="type-large">For more than 15 years, I've helped agencies, nonprofits, public companies, and publishers develop accessible, high-performance websites, reports, and digital communications platforms. Many of these partners have returned for multiple engagements, and I’m grateful for their continued trust.</p>
      </div>

      <div class="columns-12 lg:columns-3 lg:ml-1">
        <figure class="spotlight">
          <video id="spotlight-video" width="1440" height="900" src="{{ '/assets/video/fnih.mp4' | url }}" muted playsinline loop autoplay></video>
          <button type="button" class="video-btn" aria-label="Play video" aria-controls="spotlight-video" id="spotlight-video-toggle">
            {% svg "play-button.svg" %}
          </button>
          <figcaption class="sr-only">Animated homepage designs from the Foundation for the National Institutes of Health (FNIH) annual reports, featuring the 2018, 2019, and 2020 editions.</figcaption>
        </figure>
      </div>
    </div>

    <div class="columns row-gap-8xl">
      <div class="columns-12 lg:columns-6">
        <h2>Clients Index</h2>

        <ul class="about__clients">
          {%- for client in clients -%}
            <li {% if client.count > 1 %}data-count="{{client.count}}"{%endif%}>
              {{client.name}}
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="columns-6 md:columns-4 lg:columns-2 lg:ml-1">
        <h2>Technologies</h2>
        <ul>
          <li>11ty</li>
          <li>Jekyll</li>

          <li>HTML</li>
          <li>CSS / SCSS</li>
          <li>JavaScript</li>
          <li>Node.js</li>

          <li>Nunjucks</li>
          <li>Liquid</li>
          <li>Jinja2</li>
        </ul>
      </div>

      <div class="columns-6 md:columns-4 lg:columns-2">
        <h2>Services</h2>
        <ul>
          <li>Sustainability Reports</li>
          <li>Corporate Communications</li>
          <li>Annual Reports</li>
          <li>Investor Relations Websites</li>
          <li>Microsites & Campaign Sites</li>

          <li>Static Site Architecture</li>
          <li>Data Visualization</li>
          <li>Interactive Charts & Tables</li>
          <li>Accessibility (WCAG)</li>
          <li>Performance Optimization</li>
          <li>Analytics & Measurement</li>
          <li>Technical Consulting</li>
        </ul>
      </div>
    </div>
  </div>
</section>

{#
      <div class="columns-12 lg:columns-4 lg:ml-3">
        <h2>Featured Work</h2>

        <ul class="about__featured type-medium">
          {% for item in featured %}
            {% set clientSlug = item.client | slugify %}
            <li>
              <a class="js-project link" href="/gallery/{{ item.client | slugify }}-{{item.year}}/">{{ item.client }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
