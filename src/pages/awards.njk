---
layout: base.njk
isHorizontal: true
title: "Awards"
order: 4
---

<section class="awards fullscreen" id="awards">
  <div class="wrapper scroller" style="--count: {{awards.length}}">
    <div class="scroller__track">

      {% for group in awards %}
        <div class="scroller__item" data-inview>
          <div class="scroller__counter" style="z-index:{{loop.index}}">0{{loop.index}}.</div>

          <div class="stat">
            <h2 class="type-large flex flex-wrap mb-2xl">
              {%- for char in group.organization.split('') -%}
                <i data-reveal data-stagger="25">{{- char -}}</i>
              {%- endfor -%}
            </h2>

            <ul>
              {%- for award in group.awards -%}
                <li data-reveal>
                  <a href="{{ award.url }}" target="_blank" rel="noopener noreferrer" data-title="{{ award.year }}&mdash;{{ award.title }}">
                    {{ award.year }}&mdash;{{ award.client }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        </div>
      {% endfor %}

    </div>
  </div>
</section>